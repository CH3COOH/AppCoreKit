          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您输入的内容将不会被保存。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "您輸入的內容將不會被儲存。"
