        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सेटिंग्स ऐप में एक मेल खाता सेट करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "設定アプリでメールアカウントを設定してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "설정 앱에서 메일 계정을 설정하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Configure uma conta de e-mail no app Configurações."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请在「设置」应用中设置邮件账户。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請在「設定」應用程式中設定郵件帳號。"
          }
        }
      }
    },
