    "feedback.discard_changes_message": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لن يتم حفظ المحتوى الذي أدخلته."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der eingegebene Inhalt wird nicht gespeichert."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The content you entered will not be saved."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El contenido ingresado no se guardará."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le contenu saisi ne sera pas enregistré."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपने जो सामग्री दर्ज की वह सहेजी नहीं जाएगी।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "入力した内容は保存されません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
