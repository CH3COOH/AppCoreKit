    "feedback.cannot_send_mail_message": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يرجى إعداد حساب بريد إلكتروني في تطبيق الإعدادات."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitte richten Sie in der Einstellungs-App ein E-Mail-Konto ein."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please set up a mail account in the Settings app."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Configure una cuenta de correo en la app de Configuración."
          }
        },
        "fr": {
