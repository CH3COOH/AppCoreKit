    "feedback.footer_text": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "نراجع دائمًا جميع آرائكم وملاحظاتكم واستفساراتكم، ولكننا لا نضمن الرد أو المتابعة بشكل فردي. نشكركم على تفهمكم."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir lesen alle Rückmeldungen, Kommentare und Anfragen sorgfältig, können jedoch keine individuelle Antwort oder Bearbeitung zusagen. Vielen Dank für Ihr Verständnis."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We review all feedback, comments, and inquiries we receive, but we cannot guarantee an individual response or action. Thank you for your understanding."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Revisamos todas las opiniones, comentarios y consultas que recibimos, pero no podemos garantizar una respuesta o gestión individual. Gracias por su comprensión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous examinons toujours tous les avis, commentaires et demandes reçus, mais nous ne pouvons pas garantir une réponse ou un traitement individuel. Merci de votre compréhension."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हम आपके सभी विचार, प्रतिक्रियाएँ और पूछताछ अवश्य देखते हैं, लेकिन प्रत्येक मामले में व्यक्तिगत उत्तर या कार्रवाई की गारंटी नहीं दे सकते। आपकी समझ के लिए धन्यवाद।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "皆様からいただいたご意見・ご感想・お問い合わせには必ず目を通しておりますが、個別に返信・対応をお約束するものではございません。何卒ご了承くださいますようお願い申し上げます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "여러분이 보내주신 의견, 소감, 문의는 모두 확인하고 있으나, 개별 회신이나 대응을 보장해 드리지는 않습니다. 너른 양해 부탁드립니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Lemos todas as opiniões, comentários e solicitações recebidos, mas não garantimos resposta ou atendimento individual. Agradecemos a compreensão."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我们会认真查看大家提交的所有意见、感想和咨询，但不承诺逐一回复或处理。敬请谅解。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "我們會仔細閱讀大家提供的所有意見、感想與詢問，但不保證逐一回覆或處理，敬請見諒。"
          }
        }
      }
    },
    "feedback.mail_send_failed_message": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فشل الإرسال. يرجى المحاولة مرة أخرى لاحقًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Senden fehlgeschlagen. Bitte versuchen Sie es später noch einmal."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Failed to send. Please try again later."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo enviar. Por favor, inténtelo de nuevo más tarde."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec de l'envoi. Veuillez réessayer plus tard."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "भेजने में विफल। कृपया बाद में पुनः प्रयास करें।"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "送信に失敗しました。しばらく時間をおいてからもう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "전송에 실패했습니다. 잠시 후 다시 시도해 주세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Falha ao enviar. Tente novamente mais tarde."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "发送失败，请稍后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "傳送失敗，請稍後再試。"
          }
        }
      }
    },
